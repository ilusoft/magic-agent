# Environment Configuration
# Copy this file to .env and fill in your values

# Path to agent/workflow JSON definitions (relative to backend-py root)
CONFIGS_PATH=../configs/agents

# LLM Provider: openai, azure-openai, or openai-compatible
LLM_PROVIDER=azure-openai

# Azure OpenAI Configuration
LLM_ENDPOINT=https://your-resource.openai.azure.com
LLM_API_KEY=${AZURE_OPENAI_KEY}
LLM_DEPLOYMENT=gpt-4o
LLM_MODEL=gpt-4o
# LLM_API_VERSION=2024-08-01-preview

# OpenAI Configuration (when LLM_PROVIDER=openai)
# OPENAI_API_KEY=${OPENAI_KEY}
# OPENAI_MODEL=gpt-4o

# OpenAI-Compatible Configuration (when LLM_PROVIDER=openai-compatible)
# Points the LangChain client at any server that speaks the OpenAI
# /v1/chat/completions API (vLLM, llama.cpp, Ollama, LM Studio, etc.).
# LLM_BASE_URL=http://127.0.0.1:8000/v1
# LLM_MODEL=qwen-3.6
# LLM_API_KEY=not-needed   # most local servers ignore the key

# Runtime Limits
MAX_ITERATIONS=50
DEFAULT_TIMEOUT_SECONDS=120

# CORS Origins (comma-separated)
CORS_ORIGINS=["http://localhost:5173"]

# Logging
LOG_LEVEL=INFO