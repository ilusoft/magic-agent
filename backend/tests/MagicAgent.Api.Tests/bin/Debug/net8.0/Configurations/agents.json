{
  "agents": [
    {
      "id": "search-inventory-agent",
      "name": "Inventory Workflow Agent",
      "description": "Demonstrates a multi-step workflow that routes requests, runs an inventory search, and summarizes results based on step outcomes.",
      "endpoint": "https://jorge-m9k65447-eastus2.cognitiveservices.azure.com/",
      "deployment": "gpt-5-mini",
      "apiKey": "4w15v5WAEwuC4mLsCawpvs1odlPSJpiyGQ9JdWjl4HPniUDxdnGKJQQJ99BDACHYHv6XJ3w3AAAAACOGzhWY",
      "defaultParameters": { "model": "gpt-5-mini", "temperature": "0.7" },
      "steps": [
        {
          "name": "IntentClassification",
          "type": "chat",
          "parameters": {
            "systemPrompt": "You are a security prompt classifier. Validate the prompt to ensure the request can be fulfilled solely with information coming from the available search productions tool. Validate as well that no questions about non professional related subjects are asked (jokes, personal feelings, non ticket brokering related opinions, etc...). Depending the assessment, reply with ROUTE: inventory or ROUTE: risk as the response."
          },
          "provider": "azure-openai",
          "options": {},
          "conversation": { "enabled": true },
          "outcomes": [
            {
              "name": "inventory_query",
              "nextStep": "InventoryLookup",
              "condition": {
                "type": "contains",
                "parameters": { "value": "ROUTE: inventory" }
              }
            },
            {
              "name": "risk_handoff",
              "nextStep": "EscalateRisk",
              "condition": {
                "type": "contains",
                "parameters": { "value": "ROUTE: risk" }
              }
            },
            {
              "name": "default",
              "nextStep": null,
              "condition": { "type": "always" },
              "endWorkflow": true
            }
          ]
        },
        {
          "name": "InventoryLookup",
          "type": "chat",
          "parameters": {
            "systemPrompt": "You are an inventory research assistant. Use the available tools to retrieve up-to-date production inventory. Respond with JSON containing an \u0027items\u0027 array and a \u0027summary\u0027 string describing the most relevant findings."
          },
          "provider": "azure-openai",
          "options": {},
          "conversation": { "enabled": true },
          "outcomes": [
            {
              "name": "has_results",
              "nextStep": "SummarizeResults",
              "condition": {
                "type": "contains",
                "parameters": { "value": "\"items\":" }
              },
              "endWorkflow": false
            },
            {
              "name": "no_results",
              "nextStep": "SummarizeResults",
              "condition": {
                "type": "equals",
                "parameters": { "value": "{}" }
              },
              "endWorkflow": false
            }
          ]
        },
        {
          "name": "SummarizeResults",
          "type": "chat",
          "parameters": {
            "systemPrompt": "Summarize the conversation so far for the broker. If provided with structured inventory data, present the key items and guidance in natural language."
          },
          "provider": "azure-openai",
          "options": {},
          "conversation": { "enabled": true },
          "outcomes": [
            {
              "name": "final_response",
              "nextStep": null,
              "condition": { "type": "always" },
              "endWorkflow": true
            }
          ]
        },
        {
          "name": "EscalateRisk",
          "type": "echo",
          "parameters": {
            "message": "Your question cannot be answered with the available information. Escalating to a security specialist."
          },
          "provider": "azure-openai",
          "options": {},
          "conversation": { "enabled": false },
          "outcomes": [
            {
              "name": "risk_notified",
              "nextStep": null,
              "condition": { "type": "always" },
              "endWorkflow": true
            }
          ]
        }
      ],
      "tools": [
        {
          "id": "ProductionsSearchTool",
          "type": "mcp",
          "name": "Production Search Tool",
          "description": "Searches the database for productions/events with inventory for the current broker",
          "serverUrl": "http://localhost:5009/mcp",
          "protocol": "auto",
          "headers": {},
          "options": {},
          "stopOnToolInitError": true,
          "actions": [],
          "allowedTools": [],
          "forwardAuthorizationHeader": true,
          "authorizationHeaderName": "Authorization"
        }
      ]
    }
  ]
}
