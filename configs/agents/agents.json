{
  "agents": [
    {
      "id": "multi-language-translator-qwen-local",
      "name": "Multi Language Translator - Qwen Local LLM",
      "description": "Agent to translate text into multiple languages (local qwen 3.5 via OpenAI-compatible endpoint)",
      "baseUrl": "http://127.0.0.1:8000/v1",
      "model": "qwen-3.5",
      "defaultParameters": {
        "temperature": "1"
      },
      "steps": [
        {
          "name": "general chat agent",
          "type": "agent",
          "parameters": {
            "systemPrompt": "You are an expert ${{ var.languages.values[iterator] }} translator agent. You should take any input text provided and translate it. The only expected output is the translated text.",
            "message": "{{var.originalInput}}"
          },
          "variableTypes": {},
          "provider": "openai-compatible",
          "options": {},
          "conversation": {
            "enabled": true
          },
          "tools": [],
          "stopOnToolError": false,
          "inputSource": "usePrevious",
          "outcomes": [
            {
              "name": "agent-response",
              "nextStep": "set-out-vars",
              "condition": null,
              "endWorkflow": false,
              "order": 2
            },
            {
              "name": "check-languages-length",
              "nextStep": "increment-iterator",
              "condition": {
                "expression": "var.iterator < arrayLength( var.languages.values )"
              },
              "endWorkflow": false,
              "order": 1
            }
          ],
          "isStartStep": false
        },
        {
          "name": "set-initial-vars",
          "type": "setVariables",
          "parameters": {
            "originalInput": "{{input}}",
            "languages": "${{ { \"values\": [\"spanish\", \"french\", \"german\", \"portuguese\"] } }}",
            "iterator": "0",
            "translations": "${{ [] }}"
          },
          "variableTypes": {
            "originalInput": "string",
            "languages": "json",
            "iterator": "number",
            "translations": "json"
          },
          "provider": "openai-compatible",
          "options": {},
          "conversation": null,
          "tools": [],
          "stopOnToolError": false,
          "inputSource": "usePrevious",
          "outcomes": [
            {
              "name": "go-to-chat",
              "nextStep": "general chat agent",
              "condition": null,
              "endWorkflow": false,
              "order": 1
            }
          ],
          "isStartStep": true
        },
        {
          "name": "set-out-vars",
          "type": "setVariables",
          "parameters": {
            "translations": "${{ addToArray(var.translations, lastOutput) }}",
            "combinedOutput": "{{var.originalInput}} ==> \n                 \n   - Spanish : \n        ${{ var.translations[0] }}\n   \n   - French :\n        ${{ var.translations[1] }}\n\n   - German :\n        ${{ var.translations[2] }}\n\n   - Portuguese :\n        ${{ var.translations[3] }}"
          },
          "variableTypes": {
            "translations": "json",
            "combinedOutput": "string"
          },
          "provider": "openai-compatible",
          "options": {},
          "conversation": null,
          "tools": [],
          "stopOnToolError": false,
          "inputSource": "usePrevious",
          "outcomes": [
            {
              "name": "to-echo",
              "nextStep": "output-echo",
              "condition": null,
              "endWorkflow": false,
              "order": 1
            }
          ],
          "isStartStep": false
        },
        {
          "name": "output-echo",
          "type": "echo",
          "parameters": {
            "message": "{{var.combinedOutput}}"
          },
          "variableTypes": {},
          "provider": "openai-compatible",
          "options": {},
          "conversation": null,
          "tools": [],
          "stopOnToolError": false,
          "inputSource": "usePrevious",
          "outcomes": [
            {
              "name": "finish",
              "nextStep": null,
              "condition": null,
              "endWorkflow": true,
              "order": 1
            }
          ],
          "isStartStep": false
        },
        {
          "name": "increment-iterator",
          "type": "setVariables",
          "parameters": {
            "iterator": "${{ var.iterator + 1 }}",
            "translations": "${{ addToArray(var.translations, lastOutput) }}"
          },
          "variableTypes": {
            "iterator": "number",
            "translations": "json"
          },
          "provider": "openai-compatible",
          "options": {},
          "conversation": null,
          "tools": [],
          "stopOnToolError": false,
          "inputSource": "usePrevious",
          "outcomes": [
            {
              "name": "continue",
              "nextStep": "general chat agent",
              "condition": {
                "expression": "true"
              },
              "endWorkflow": false,
              "order": 1
            }
          ],
          "isStartStep": false
        }
      ],
      "tools": [],
      "ViewLayout": {
        "nodes": {
