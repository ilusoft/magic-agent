      ],
      "actions": [
        {
          "name": "web_search",
          "description": "Search the public web for up-to-date information about a query. Use this when you need recent facts, news, or references.",
          "parameters": {
            "tool": "tavily_search"
          }
        },
        {
          "name": "fetch_page",
          "description": "Fetch and extract the full text content from a list of URLs returned by web_search.",
          "parameters": {
            "tool": "tavily_extract"
          }
        }
      ],
      "forwardAuthorizationHeader": false,
      "stopOnToolInitError": false
    }
