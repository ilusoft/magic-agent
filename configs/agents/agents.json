    "tavily-mcp": {
      "id": "tavily-mcp",
      "type": "mcp",
      "name": "TavilyWebSearch",
      "description": "Tavily MCP server providing web search, extract, crawl, and map tools.",
      "serverUrl": "https://mcp.tavily.com/mcp/?tavilyApiKey=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",
      "protocol": "auto",
      "allowedTools": [
