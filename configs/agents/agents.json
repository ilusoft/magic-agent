    {
      "id": "web-search-tavily-qwen-local",
      "name": "Web Search Agent - Local LLM",
      "description": "Answers user questions by searching the web via the Tavily MCP, using the local Qwen LLM as the chat backend.",
      "steps": [
        {
          "name": "set-initial-vars",
          "type": "setVariables",
          "parameters": {
            "userQuestion": "{{input}}"
          },
          "variableTypes": {
            "userQuestion": "string"
          },
          "conversation": null,
          "tools": [],
          "stopOnToolError": false,
          "inputSource": "usePrevious",
          "outcomes": [
            {
              "name": "go-to-search",
              "nextStep": "web-search-agent",
              "condition": null,
              "endWorkflow": false,
              "order": 1
            }
          ],
          "isStartStep": true
        },
        {
          "name": "web-search-agent",
          "type": "agent",
          "parameters": {
            "systemPrompt": "You are a research assistant with access to the Tavily web search MCP tools. \n\nCurrent Date Time : ${{ today }}\n\nTo answer the user's question: \n\n(1) call web_search with a focused query to find the most relevant and recent sources\n(2) optionally call fetch_page on the top URLs to read their full content\n(3) synthesize a concise, well-cited answer in plain text. Always prefer authoritative and current sources. \n\nIMPORTANT RULES:\n- Never invent facts — when the web does not contain an answer, say so explicitly.\n- If you cannot find an answer with a maximum of 2 research calls to the tools don't try any further and consolidate the facts found or ask for clarifications to the user.\n\nOUTPUT FORMAT:\n- Consolidate the results and try to answer as brief as possible. Don't show the user all the details of the research just the elaborated answer.",
            "message": "{{var.userQuestion}}"
          },
          "conversation": {
            "enabled": true
          },
          "outcomes": [
            {
              "name": "answer-ready",
              "nextStep": "output-echo",
              "condition": null,
              "endWorkflow": false,
              "order": 1
            }
          ],
          "tools": [
            "tavily-mcp"
          ],
          "llmConfig": {
            "profileId": "multi-language-translator-qwen-local-default"
          }
        },
        {
          "name": "output-echo",
          "type": "echo",
          "parameters": {
            "message": "{{lastOutput}}"
          },
          "variableTypes": {},
          "conversation": null,
          "tools": [],
          "stopOnToolError": false,
          "inputSource": "usePrevious",
          "outcomes": [
            {
              "name": "finish",
              "nextStep": null,
              "condition": null,
              "endWorkflow": true,
              "order": 1
            }
          ],
          "isStartStep": false
        }
      ],
      "streaming": {
        "enabled": true,
        "mode": "sse"
      },
